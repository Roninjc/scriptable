#!/bin/sh
# Keeps config/scripts-meta.json in sync with staged .js files before committing.
# Enable once per clone with:  git config core.hooksPath .githooks
if command -v node >/dev/null 2>&1; then
  node "$(git rev-parse --show-toplevel)/config/update-meta.js" || exit 1
else
  echo "scripts-meta hook: node not found, skipping meta update" >&2
fi
